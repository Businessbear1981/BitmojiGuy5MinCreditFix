# ── AE 5-Min Credit Fix — Environment Configuration ─────────────────────────
# Backend = FastAPI (backend/), Frontend = Next.js (frontend/).
# In production every secret below MUST be set; the backend fails closed.

# ── Backend (Railway) ────────────────────────────────────────────────────────
# "production" enforces fail-closed secrets; anything else allows dev fallbacks
ENVIRONMENT=development

# Postgres in production (Railway/Supabase). Defaults to local SQLite in dev.
DATABASE_URL=postgresql://user:pass@host:5432/creditfix

# 32-byte urlsafe-base64 key for field-level PII encryption at rest.
# Generate: python -c "import base64,os;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
PII_ENCRYPTION_KEY=

# Secret for signing short-lived terms-acceptance tokens (any long random string)
TERMS_TOKEN_SECRET=

# Admin API key — no default; admin endpoints are disabled if unset
ADMIN_KEY=

# Per-session upload encryption (Cypher module)
CYPHER_SERVER_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Lob certified mail
LOB_API_KEY=
LOB_WEBHOOK_SECRET=

# Claude-powered report analysis (falls back to keyword scanner if unset)
ANTHROPIC_API_KEY=
# Optional — defaults to claude-haiku-4-5-20251001 (cheap, fast extraction)
ANTHROPIC_MODEL=

# Outbound email (SendGrid SMTP by default)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@ardanedgecapital.com

# Where Stripe redirects the customer after checkout (the deployed frontend)
FRONTEND_URL=http://localhost:3000

# Comma-separated CORS allowlist (never * in production)
ALLOWED_ORIGINS=http://localhost:3000

# Demo mode: fakes mail/email side effects when providers aren't configured
DEMO_MODE=false

# Optional Sentry error tracking (disabled when unset; PII scrubbing enforced)
SENTRY_DSN=

# ── Frontend (Vercel) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
