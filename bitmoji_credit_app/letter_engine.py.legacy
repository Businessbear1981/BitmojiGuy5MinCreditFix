# ═══════════════════════════════════════════════════════════════════════════════
# STATE LAW REFERENCES (imported from app.py at runtime)
# ═══════════════════════════════════════════════════════════════════════════════

def _get_state_block(state_code, state_laws):
    """Build state-specific legal paragraph."""
    law = state_laws.get(state_code)
    if not law:
        return ''
    sol = law.get('sol_written', '')
    parts = [
        f'\nAPPLICABLE STATE LAW ({law["name"].upper()}):',
        f'Statute of limitations for written contracts: {sol} years ({law.get("statute", "")})',
        f'Consumer protection: {law.get("consumer_act", "")}',
    ]
    if law.get('extra'):
        parts.append(law['extra'])
    return '\n'.join(parts)


# ═══════════════════════════════════════════════════════════════════════════════
# LETTER COMPOSER — one letter per recipient per item
# ═══════════════════════════════════════════════════════════════════════════════

def compose_letter(
    consumer_name: str,
    consumer_address: str,
    recipient: dict,       # {'name': ..., 'address': ...}
    item: dict,            # parsed dispute item from parser
    ground: dict,          # GROUND_TYPES entry
    state_code: str,
    state_laws: dict,
    date_str: str = None,
) -> dict:
    """
    Compose a single dispute letter.

    Returns dict with 'recipient_name', 'recipient_address', 'subject', 'body'.
    No AE branding. No customer numbers. No generator strings.
    """
    if not date_str:
        date_str = datetime.utcnow().strftime('%B %d, %Y')

    # ── Build the account audit section ──────────────────────────────────────
    audit_lines = []
    if item.get('creditor'):
        audit_lines.append(f'Account Name: {item["creditor"]}')
    if item.get('account_number'):
        audit_lines.append(f'Account Number: {item["account_number"]}')
    if item.get('amount'):
        audit_lines.append(f'Reported Balance: {item["amount"]}')
    if item.get('date'):
        audit_lines.append(f'Date Reported: {item["date"]}')
    if item.get('type') and item['type'] != 'negative_item':
        audit_lines.append(f'Status: {item["type"].replace("_", " ").title()}')

    audit_section = '\n'.join(audit_lines) if audit_lines else 'See details below'

    # ── Build the letter body (math-first structure) ─────────────────────────
    sections = []

    # 1. Opening
    sections.append(f'{date_str}\n')
    sections.append(f'{consumer_name}')
    if consumer_address:
        sections.append(f'{consumer_address}')
    sections.append('')
    sections.append(f'{recipient["name"]}')
    sections.append(f'{recipient["address"]}')
    sections.append('')
    sections.append(f'Re: Dispute of Information on Consumer Report')
    sections.append('')

    # 2. Account audit — specific data points lead
    sections.append('ACCOUNT INFORMATION IN DISPUTE:')
    sections.append(audit_section)
    sections.append('')

    # 3. Consumer factual position — sourced from affirmed ground
    sections.append('CONSUMER STATEMENT:')
    sections.append(ground['position'])
    sections.append('')

    # 4. Specific requests
    sections.append('SPECIFIC REQUESTS:')
    for i, req in enumerate(ground['requests'], 1):
        sections.append(f'{i}. {req}')
    sections.append('')

    # 5. Statutory grounding — closes the letter
    sections.append('LEGAL BASIS:')
    for statute in ground['statutes']:
        sections.append(f'- {statute}')

    # 6. State law (if applicable)
    state_block = _get_state_block(state_code, state_laws)
    if state_block:
        sections.append(state_block)

    sections.append('')
    sections.append(
        'I expect a response within 30 days as required by law. If you cannot '
        'verify the disputed information, it must be corrected or deleted.'
    )
    sections.append('')
    sections.append('Sincerely,')
    sections.append(f'{consumer_name}')

    body = '\n'.join(sections)

    return {
        'recipient_name': recipient['name'],
        'recipient_address': recipient['address'],
        'subject': f'Dispute — {item.get("creditor", "Account")} — {ground["label"]}',
        'body': body,
        'framework': ground['framework'],
        'ground_type': [k for k, v in GROUND_TYPES.items() if v is ground][0],
        'item_creditor': item.get('creditor', ''),
        'item_account': item.get('account_number', ''),
    }


# ═══════════════════════════════════════════════════════════════════════════════
# MAIN GENERATOR — takes affirmed items + grounds, produces letters
# ═══════════════════════════════════════════════════════════════════════════════

def generate_letters_v2(
    affirmed_items: list,   # list of {item: ..., ground_key: ..., bureaus: [...]}
    consumer_name: str,
    consumer_address: str,
    state_code: str,
    state_laws: dict,
) -> list:
    """
    Generate dispute letters from consumer-affirmed items and grounds.

    Each entry in affirmed_items:
    {
        'item': { creditor, account_number, amount, date, type, ... },
        'ground_key': 'not_mine' | 'confirmed_fraud' | 'validate_debt' | etc.,
        'bureaus': ['equifax', 'experian', 'transunion']  # for bureau letters
        'collector_name': '...',    # for collector letters
        'collector_address': '...',  # for collector letters
    }

    Returns list of letter dicts ready for display/print/mail.
    One letter per recipient per item. No stacking.
    """
    letters = []
    date_str = datetime.utcnow().strftime('%B %d, %Y')

    for entry in affirmed_items:
        item = entry['item']
        ground_key = entry.get('ground_key', 'not_mine')
        ground = GROUND_TYPES.get(ground_key)
        if not ground:
            continue

        if ground['recipient'] == 'bureau':
            # One letter per bureau for this item
            target_bureaus = entry.get('bureaus', ['equifax', 'experian', 'transunion'])
            for bureau_key in target_bureaus:
                bureau = BUREAUS.get(bureau_key)
                if not bureau:
                    continue
                letter = compose_letter(
                    consumer_name=consumer_name,
                    consumer_address=consumer_address,
                    recipient=bureau,
                    item=item,
                    ground=ground,
                    state_code=state_code,
                    state_laws=state_laws,
                    date_str=date_str,
                )
                letters.append(letter)

        elif ground['recipient'] == 'collector':
            # One letter to the collector
            collector = {
                'name': entry.get('collector_name', item.get('creditor', 'Collection Agency')),
                'address': entry.get('collector_address', 'Address on file'),
            }
            letter = compose_letter(
                consumer_name=consumer_name,
                consumer_address=consumer_address,
                recipient=collector,
                item=item,
                ground=ground,
                state_code=state_code,
                state_laws=state_laws,
                date_str=date_str,
            )
            letters.append(letter)

    return letters


