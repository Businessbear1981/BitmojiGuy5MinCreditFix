def add_operator_note(session_id: str, operator_username: str, note: str):
    conn = _get_admin_db()
    conn.execute(
        "INSERT INTO operator_notes (session_id, operator_username, note, created_at) VALUES (?, ?, ?, ?)",
        (session_id, operator_username, note, datetime.utcnow().isoformat())
    )
    conn.commit()
    conn.close()
    log_action(operator_username, 'add_note', session_id, '', note[:100])


def get_operator_notes(session_id: str) -> list:
    conn = _get_admin_db()
    rows = conn.execute(
        "SELECT * FROM operator_notes WHERE session_id = ? ORDER BY created_at DESC", (session_id,)
    ).fetchall()
    conn.close()
    return [dict(r) for r in rows]


# ═══════════════════════════════════════════════════════════════════════════════
# NOTIFICATIONS / QUEUE
# ═══════════════════════════════════════════════════════════════════════════════

def get_notifications(clients_fn) -> dict:
    """
    Get operator notifications. clients_fn should be a callable that returns
    all clients (e.g. database.get_all_clients_admin).
    """
    clients = clients_fn()
    now = datetime.utcnow()
    notifications = {
        'awaiting_release': [],
        'mailing_overdue': [],
        'response_window_closing': [],
        'errors': [],
    }

    for c in clients:
        sid = c.get('session_id', '')
        status = c.get('status', '')
        name = c.get('name', c.get('initials', '??'))

        # Awaiting release — paid but not released
        if c.get('paid') and status in ('paid', 'awaiting_release'):
            if not is_released(sid):
                notifications['awaiting_release'].append({
                    'session_id': sid, 'name': name,
                    'since': c.get('paid_at', ''),
                })

        # Released but not mailed within 7 days
        if is_released(sid):
            statuses = get_letter_statuses(sid)
            released_letters = [s for s in statuses if s['status'] == 'released']
            for ls in released_letters:
                released_at = ls.get('released_at', '')
                if released_at:
                    try:
                        rd = datetime.fromisoformat(released_at)
                        if (now - rd).days >= 7:
                            notifications['mailing_overdue'].append({
                                'session_id': sid, 'name': name,
                                'bureau': ls.get('bureau', ''),
                                'days_since_release': (now - rd).days,
                            })
                    except (ValueError, TypeError):
                        pass

        # 30-day window closing (within 5 days)
        statuses = get_letter_statuses(sid)
        mailed_letters = [s for s in statuses if s['status'] == 'mailed']
        for ls in mailed_letters:
            mailed_at = ls.get('mailed_at', '')
            if mailed_at:
                try:
                    md = datetime.fromisoformat(mailed_at)
                    days_since = (now - md).days
                    if 25 <= days_since <= 30:
                        notifications['response_window_closing'].append({
                            'session_id': sid, 'name': name,
                            'bureau': ls.get('bureau', ''),
                            'days_remaining': 30 - days_since,
                        })
                except (ValueError, TypeError):
                    pass

    return notifications


# ═══════════════════════════════════════════════════════════════════════════════
# FLASK BLUEPRINT — API routes
# ═══════════════════════════════════════════════════════════════════════════════

admin_bp = Blueprint('admin_dashboard', __name__, url_prefix='/op-console')


def require_operator(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        if not session.get('operator_authenticated'):
            return jsonify(error='Authentication required'), 401
        # Check session timeout (30 min inactivity)
        last_activity = session.get('operator_last_activity')
        if last_activity:
            try:
                la = datetime.fromisoformat(last_activity)
                if (datetime.utcnow() - la).seconds > 1800:
                    session.pop('operator_authenticated', None)
                    return jsonify(error='Session expired — please log in again'), 401
            except (ValueError, TypeError):
                pass
        # Check max session length (8 hours)
        login_time = session.get('operator_login_time')
        if login_time:
            try:
                lt = datetime.fromisoformat(login_time)
                if (datetime.utcnow() - lt).seconds > 28800:
                    session.pop('operator_authenticated', None)
                    return jsonify(error='Maximum session length exceeded'), 401
            except (ValueError, TypeError):
                pass
        session['operator_last_activity'] = datetime.utcnow().isoformat()
        return f(*args, **kwargs)
    return decorated


@admin_bp.route('/api/login', methods=['POST'])
def op_login():
    data = request.get_json(force=True)
    result = verify_operator(
        data.get('username', ''),
        data.get('password', ''),
        data.get('totp_code', ''),
    )
    if result.get('ok'):
        session['operator_authenticated'] = True
        session['operator_username'] = result['username']
        session['operator_id'] = result['operator_id']
        session['operator_login_time'] = datetime.utcnow().isoformat()
        session['operator_last_activity'] = datetime.utcnow().isoformat()
        log_action(result['username'], 'login', '', '', 'Operator logged in')
        return jsonify(ok=True, username=result['username'])
    return jsonify(error=result.get('error', 'Login failed')), 401


@admin_bp.route('/api/logout', methods=['POST'])
def op_logout():
    username = session.get('operator_username', '')
    session.pop('operator_authenticated', None)
    session.pop('operator_username', None)
    if username:
        log_action(username, 'logout', '', '', 'Operator logged out')
    return jsonify(ok=True)


@admin_bp.route('/api/queue')
@require_operator
def op_queue():
    """Main dashboard queue — all consumers sorted by attention priority."""
    from database import get_all_clients_admin
    clients = get_all_clients_admin()

    # Enrich with release status and letter info
    queue = []
    for c in clients:
        sid = c['session_id']
        released = is_released(sid)
        letters = get_letter_statuses(sid)

        # Determine state
        if c.get('paid') and not released:
            state = 'awaiting_release'
            priority = 1
        elif released and any(l['status'] == 'released' for l in letters):
            state = 'released'
            priority = 2
        elif any(l['status'] == 'mailed' for l in letters):
            state = 'mailed'
            priority = 3
        elif any(l['status'] == 'response_received' for l in letters):
            state = 'response_received'
            priority = 4
        elif c.get('status') in ('started', 'parsed'):
            state = 'in_progress'
            priority = 5
        else:
            state = c.get('status', 'unknown')
            priority = 6

        # Days since last action
        updated = c.get('updated_at') or c.get('created_at', '')
        days_since = 0
        if updated:
            try:
                days_since = (datetime.utcnow() - datetime.fromisoformat(updated)).days
            except (ValueError, TypeError):
                pass

        queue.append({
            'session_id': sid,
            'name': c.get('name', c.get('initials', '??')),
            'email': c.get('email', ''),
            'state': state,
            'priority': priority,
            'confirmation': c.get('confirmation', ''),
            'paid': bool(c.get('paid')),
            'paid_at': c.get('paid_at', ''),
            'dispute_count': c.get('dispute_count', 0),
            'days_since_action': days_since,
            'created_at': c.get('created_at', ''),
            'letter_count': len(letters),
            'referral_source': c.get('referral_source', ''),
        })

    # Sort by priority, then newest first within each priority
    queue.sort(key=lambda q: (q['priority'], q.get('paid_at', '') or ''), reverse=False)

    return jsonify(ok=True, queue=queue, total=len(queue))


@admin_bp.route('/api/consumer/<session_id>')
@require_operator
def op_consumer_detail(session_id):
    """Per-consumer detail view."""
    from database import load_client_by_session
    profile = load_client_by_session(session_id)
    if not profile:
        return jsonify(error='Consumer not found'), 404

    letters = get_letter_statuses(session_id)
    release_info = None
    conn = _get_admin_db()
    rel = conn.execute("SELECT * FROM letter_releases WHERE session_id = ? ORDER BY id DESC LIMIT 1", (session_id,)).fetchone()
    conn.close()
    if rel:
        release_info = dict(rel)

    notes = get_operator_notes(session_id)
    audit = get_audit_log(session_id, limit=50)
    released = is_released(session_id)

    return jsonify(
        ok=True,
        consumer={
            'name': profile.get('name', ''),
            'email': profile.get('email', ''),
            'phone': profile.get('phone', ''),
            'address': profile.get('address', ''),
            'state': profile.get('state', ''),
            'status': profile.get('status', ''),
            'paid': profile.get('paid', False),
            'paid_at': profile.get('paid_at', ''),
            'created_at': profile.get('created_at', ''),
            'confirmation': profile.get('confirmation', ''),
            'dispute_count': len(profile.get('dispute_items', [])),
            'dispute_items': profile.get('dispute_items', []),
        },
        letters=letters,
        release=release_info,
        released=released,
        notes=notes,
        audit_log=audit,
    )


@admin_bp.route('/api/release', methods=['POST'])
@require_operator
def op_release():
    """Release letters — requires manual entry of payment details."""
    data = request.get_json(force=True)
    sid = data.get('session_id', '')
    amount = data.get('payment_amount', '')
    method = data.get('payment_method', '')
    reference = data.get('transaction_reference', '')

    if not all([sid, amount, method, reference]):
        return jsonify(error='All fields required: session_id, payment_amount, payment_method, transaction_reference'), 400

    operator = session.get('operator_username', 'unknown')
    result = release_letters(sid, amount, method, reference, operator)

    if result.get('ok'):
        # Also mark paid in main DB if not already
        from database import load_client_by_session, save_client
        profile = load_client_by_session(sid)
        if profile and not profile.get('paid'):
            profile['paid'] = True
            profile['paid_at'] = datetime.utcnow().isoformat()
            profile['status'] = 'released'
            save_client(profile)

    return jsonify(result)


@admin_bp.route('/api/revoke', methods=['POST'])
@require_operator
def op_revoke():
    """Revoke letter access — strong confirmation required."""
    data = request.get_json(force=True)
    confirm_text = data.get('confirm_text', '')
    if confirm_text != 'REFUND AND REVOKE':
        return jsonify(error='Type "REFUND AND REVOKE" to confirm'), 400

    sid = data.get('session_id', '')
    reason = data.get('reason', '')
    refund_amount = data.get('refund_amount', '')
    already_mailed = data.get('already_mailed', False)

    if not sid or not reason:
        return jsonify(error='session_id and reason required'), 400

    operator = session.get('operator_username', 'unknown')
    result = revoke_letters(sid, reason, refund_amount, already_mailed, operator)
    return jsonify(result)


