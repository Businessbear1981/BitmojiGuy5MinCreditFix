@admin_bp.route('/api/setup-operator', methods=['POST'])
def op_setup():
    """One-time operator setup. Only works if no operators exist."""
    conn = _get_admin_db()
    count = conn.execute("SELECT COUNT(*) as c FROM operators").fetchone()['c']
    conn.close()
    if count > 0:
        return jsonify(error='Operator already exists. Use existing credentials.'), 403

    data = request.get_json(force=True)
    username = data.get('username', '')
    password = data.get('password', '')
    if not username or not password or len(password) < 8:
        return jsonify(error='Username and password (8+ chars) required'), 400

    result = create_operator(username, password)
    return jsonify(result)
