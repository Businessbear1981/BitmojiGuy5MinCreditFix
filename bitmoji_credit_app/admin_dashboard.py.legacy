"""
Admin Dashboard — Operator Console
Backend routes + data layer for payment release, response logging, audit trail.

Auth: username + password + TOTP
Endpoint: /op-console (non-obvious path)
"""

import os
import json
import sqlite3
import hashlib
import secrets
import time
from datetime import datetime, timedelta
from functools import wraps

from flask import Blueprint, request, jsonify, session, redirect, url_for

# Optional TOTP — graceful if pyotp not installed
try:
    import pyotp
    HAS_TOTP = True
except ImportError:
    HAS_TOTP = False
    print('[ADMIN] pyotp not installed — TOTP disabled for dev. Install with: pip install pyotp')

try:
    import bcrypt
    HAS_BCRYPT = True
except ImportError:
    HAS_BCRYPT = False


# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════════════════════

ADMIN_DB = os.environ.get('ADMIN_DB_PATH', 'admin.db')


def _get_admin_db():
    conn = sqlite3.connect(ADMIN_DB, check_same_thread=False)
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA journal_mode=WAL")
    return conn


def init_admin_db():
    conn = _get_admin_db()
    conn.executescript("""
        CREATE TABLE IF NOT EXISTS unmatched_payments (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            sender_name TEXT,
            amount TEXT,
            received_at TEXT,
            note_contents TEXT,
            operator_notes TEXT,
            status TEXT DEFAULT 'unresolved',
            linked_session_id TEXT,
            resolved_reason TEXT,
            created_at TEXT NOT NULL,
            resolved_at TEXT
        );

        CREATE TABLE IF NOT EXISTS operators (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            username TEXT UNIQUE NOT NULL,
            password_hash TEXT NOT NULL,
            totp_secret TEXT,
            recovery_codes TEXT,
            role TEXT DEFAULT 'operator',
            created_at TEXT NOT NULL,
            last_login TEXT
        );

        CREATE TABLE IF NOT EXISTS audit_log (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            operator_id INTEGER,
            operator_username TEXT,
            action TEXT NOT NULL,
            target_session_id TEXT,
            target_consumer TEXT,
            details TEXT,
            before_state TEXT,
            after_state TEXT,
            timestamp TEXT NOT NULL
        );
        CREATE INDEX IF NOT EXISTS idx_audit_target ON audit_log(target_session_id);
        CREATE INDEX IF NOT EXISTS idx_audit_time ON audit_log(timestamp);

        CREATE TABLE IF NOT EXISTS letter_releases (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            session_id TEXT NOT NULL,
            payment_amount TEXT,
            payment_method TEXT,
            transaction_reference TEXT,
            released_at TEXT NOT NULL,
            released_by TEXT,
            revoked INTEGER DEFAULT 0,
            revoked_at TEXT,
            revoked_reason TEXT
        );
        CREATE INDEX IF NOT EXISTS idx_release_session ON letter_releases(session_id);

        CREATE TABLE IF NOT EXISTS letter_status (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            session_id TEXT NOT NULL,
            bureau TEXT NOT NULL,
            letter_type TEXT DEFAULT 'bureau',
            status TEXT DEFAULT 'preview',
            generated_at TEXT,
            released_at TEXT,
            mailed_at TEXT,
            response_received_at TEXT,
            response_outcome TEXT,
            response_notes TEXT
        );
        CREATE INDEX IF NOT EXISTS idx_lstatus_session ON letter_status(session_id);

        CREATE TABLE IF NOT EXISTS operator_notes (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            session_id TEXT NOT NULL,
            operator_username TEXT,
            note TEXT NOT NULL,
            created_at TEXT NOT NULL
        );
    """)
    conn.close()


# ═══════════════════════════════════════════════════════════════════════════════
# OPERATOR MANAGEMENT
# ═══════════════════════════════════════════════════════════════════════════════

def create_operator(username: str, password: str) -> dict:
    """Create an operator account. Returns TOTP setup info."""
    conn = _get_admin_db()
    now = datetime.utcnow().isoformat()

    # Hash password
    if HAS_BCRYPT:
        pw_hash = bcrypt.hashpw(password.encode(), bcrypt.gensalt()).decode()
    else:
        pw_hash = hashlib.sha256(password.encode()).hexdigest()

    # Generate TOTP secret
    totp_secret = ''
    totp_uri = ''
    if HAS_TOTP:
        totp_secret = pyotp.random_base32()
        totp_uri = pyotp.TOTP(totp_secret).provisioning_uri(username, issuer_name='CreditTool Operator')

    # Generate recovery codes
    recovery = [secrets.token_hex(4).upper() for _ in range(8)]
    recovery_json = json.dumps(recovery)

    try:
        conn.execute(
            "INSERT INTO operators (username, password_hash, totp_secret, recovery_codes, role, created_at) VALUES (?, ?, ?, ?, 'operator', ?)",
            (username, pw_hash, totp_secret, recovery_json, now)
        )
        conn.commit()
    except sqlite3.IntegrityError:
        conn.close()
        return {'error': 'Username already exists'}

    conn.close()
    return {
        'ok': True,
        'username': username,
        'totp_secret': totp_secret,
        'totp_uri': totp_uri,
        'recovery_codes': recovery,
    }


def verify_operator(username: str, password: str, totp_code: str = '') -> dict:
    """Verify operator credentials + TOTP."""
    conn = _get_admin_db()
    row = conn.execute("SELECT * FROM operators WHERE username = ?", (username,)).fetchone()
    conn.close()

    if not row:
        return {'error': 'Invalid credentials'}

    # Check password
    if HAS_BCRYPT:
        try:
            if not bcrypt.checkpw(password.encode(), row['password_hash'].encode()):
                return {'error': 'Invalid credentials'}
        except Exception:
            return {'error': 'Invalid credentials'}
    else:
        if hashlib.sha256(password.encode()).hexdigest() != row['password_hash']:
            return {'error': 'Invalid credentials'}

    # Check TOTP
    if HAS_TOTP and row['totp_secret']:
        totp = pyotp.TOTP(row['totp_secret'])
        if not totp.verify(totp_code, valid_window=1):
            # Check recovery codes
            try:
                codes = json.loads(row['recovery_codes'] or '[]')
            except Exception:
                codes = []
            if totp_code.upper() not in codes:
                return {'error': 'Invalid TOTP code'}
            # Consume recovery code
            codes.remove(totp_code.upper())
            c2 = _get_admin_db()
            c2.execute("UPDATE operators SET recovery_codes = ? WHERE id = ?", (json.dumps(codes), row['id']))
            c2.commit()
            c2.close()

    # Update last login
    c3 = _get_admin_db()
    c3.execute("UPDATE operators SET last_login = ? WHERE id = ?", (datetime.utcnow().isoformat(), row['id']))
    c3.commit()
    c3.close()

    return {'ok': True, 'operator_id': row['id'], 'username': row['username'], 'role': row['role']}


# ═══════════════════════════════════════════════════════════════════════════════
# AUDIT LOG
# ═══════════════════════════════════════════════════════════════════════════════

def log_action(operator_username: str, action: str, target_session_id: str = '',
               target_consumer: str = '', details: str = '',
               before_state: str = '', after_state: str = ''):
    conn = _get_admin_db()
    conn.execute(
        "INSERT INTO audit_log (operator_username, action, target_session_id, target_consumer, details, before_state, after_state, timestamp) VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
        (operator_username, action, target_session_id, target_consumer, details, before_state, after_state, datetime.utcnow().isoformat())
    )
    conn.commit()
    conn.close()


def get_audit_log(session_id: str = '', limit: int = 100) -> list:
    conn = _get_admin_db()
    if session_id:
        rows = conn.execute(
            "SELECT * FROM audit_log WHERE target_session_id = ? ORDER BY timestamp DESC LIMIT ?",
            (session_id, limit)
        ).fetchall()
    else:
        rows = conn.execute(
            "SELECT * FROM audit_log ORDER BY timestamp DESC LIMIT ?", (limit,)
        ).fetchall()
    conn.close()
    return [dict(r) for r in rows]


# ═══════════════════════════════════════════════════════════════════════════════
# LETTER RELEASE / REVOKE
# ═══════════════════════════════════════════════════════════════════════════════

def release_letters(session_id: str, payment_amount: str, payment_method: str,
                    transaction_reference: str, operator_username: str) -> dict:
    """Release letters for a consumer. Irreversible except via revoke."""
    conn = _get_admin_db()
    now = datetime.utcnow().isoformat()

    # Check not already released
    existing = conn.execute(
        "SELECT * FROM letter_releases WHERE session_id = ? AND revoked = 0", (session_id,)
    ).fetchone()
    if existing:
        conn.close()
        return {'error': 'Letters already released for this consumer'}

    conn.execute(
        "INSERT INTO letter_releases (session_id, payment_amount, payment_method, transaction_reference, released_at, released_by) VALUES (?, ?, ?, ?, ?, ?)",
        (session_id, payment_amount, payment_method, transaction_reference, now, operator_username)
    )

    # Update letter statuses
    conn.execute(
        "UPDATE letter_status SET status = 'released', released_at = ? WHERE session_id = ? AND status = 'preview'",
        (now, session_id)
    )

    conn.commit()
    conn.close()

    log_action(operator_username, 'release_letters', session_id, '',
               f'amount={payment_amount} method={payment_method} ref={transaction_reference}',
               'awaiting_release', 'released')

    return {'ok': True, 'released_at': now}


def revoke_letters(session_id: str, reason: str, refund_amount: str,
                   already_mailed: bool, operator_username: str) -> dict:
    """Revoke letter access and mark refunded."""
    conn = _get_admin_db()
    now = datetime.utcnow().isoformat()

    conn.execute(
        "UPDATE letter_releases SET revoked = 1, revoked_at = ?, revoked_reason = ? WHERE session_id = ? AND revoked = 0",
        (now, reason, session_id)
    )
    conn.execute(
        "UPDATE letter_status SET status = 'revoked' WHERE session_id = ? AND status IN ('released', 'preview')",
        (session_id,)
    )
    conn.commit()
    conn.close()

    log_action(operator_username, 'revoke_letters', session_id, '',
               f'reason={reason} refund={refund_amount} mailed={already_mailed}',
               'released', 'revoked')

    return {'ok': True, 'revoked_at': now}


# ═══════════════════════════════════════════════════════════════════════════════
# LETTER STATUS TRACKING
# ═══════════════════════════════════════════════════════════════════════════════

def create_letter_status(session_id: str, bureau: str, letter_type: str = 'bureau'):
    conn = _get_admin_db()
    conn.execute(
        "INSERT INTO letter_status (session_id, bureau, letter_type, status, generated_at) VALUES (?, ?, ?, 'preview', ?)",
        (session_id, bureau, letter_type, datetime.utcnow().isoformat())
    )
    conn.commit()
    conn.close()


def mark_letter_mailed(letter_id: int, operator_username: str = ''):
    conn = _get_admin_db()
    now = datetime.utcnow().isoformat()
    conn.execute("UPDATE letter_status SET status = 'mailed', mailed_at = ? WHERE id = ?", (now, letter_id))
    conn.commit()
    conn.close()
    if operator_username:
        log_action(operator_username, 'mark_mailed', '', '', f'letter_id={letter_id}')


def log_bureau_response(letter_id: int, outcome: str, notes: str, operator_username: str):
    conn = _get_admin_db()
    now = datetime.utcnow().isoformat()
    conn.execute(
        "UPDATE letter_status SET status = 'response_received', response_received_at = ?, response_outcome = ?, response_notes = ? WHERE id = ?",
        (now, outcome, notes, letter_id)
    )
    conn.commit()
    conn.close()
    log_action(operator_username, 'log_response', '', '', f'letter_id={letter_id} outcome={outcome}')


def get_letter_statuses(session_id: str) -> list:
    conn = _get_admin_db()
    rows = conn.execute("SELECT * FROM letter_status WHERE session_id = ? ORDER BY id", (session_id,)).fetchall()
    conn.close()
    return [dict(r) for r in rows]


def is_released(session_id: str) -> bool:
    conn = _get_admin_db()
    row = conn.execute(
        "SELECT 1 FROM letter_releases WHERE session_id = ? AND revoked = 0", (session_id,)
    ).fetchone()
    conn.close()
    return row is not None


# ═══════════════════════════════════════════════════════════════════════════════
# CONFIRMATION NUMBER GENERATION
# ═══════════════════════════════════════════════════════════════════════════════

# Unambiguous character set: no 0/O, no 1/I/l
_CONF_CHARS = 'ABCDEFGHJKMNPQRSTUVWXYZ23456789'


def generate_confirmation_number() -> str:
    """Generate a unique 6-char confirmation number for payment matching."""
    conn = _get_admin_db()
    for _ in range(100):  # collision guard
        code = ''.join(secrets.choice(_CONF_CHARS) for _ in range(6))
        existing = conn.execute(
            "SELECT 1 FROM letter_releases WHERE payment_method = 'confirmation' AND transaction_reference = ?",
            (code,)
        ).fetchone()
        if not existing:
            conn.close()
            return code
    conn.close()
    # Fallback — extend to 8 chars
    return ''.join(secrets.choice(_CONF_CHARS) for _ in range(8))


# ═══════════════════════════════════════════════════════════════════════════════
# UNMATCHED PAYMENTS
# ═══════════════════════════════════════════════════════════════════════════════

def log_unmatched_payment(sender_name: str, amount: str, received_at: str,
                          note_contents: str, operator_notes: str, operator_username: str) -> dict:
    conn = _get_admin_db()
    now = datetime.utcnow().isoformat()
    cursor = conn.execute(
        "INSERT INTO unmatched_payments (sender_name, amount, received_at, note_contents, operator_notes, created_at) VALUES (?, ?, ?, ?, ?, ?)",
        (sender_name, amount, received_at, note_contents, operator_notes, now)
    )
    pid = cursor.lastrowid
    conn.commit()
    conn.close()
    log_action(operator_username, 'log_unmatched_payment', '', '',
               f'sender={sender_name} amount={amount} note={note_contents[:50]}')
    return {'ok': True, 'payment_id': pid}


def link_unmatched_payment(payment_id: int, session_id: str, operator_username: str) -> dict:
    conn = _get_admin_db()
    now = datetime.utcnow().isoformat()
    conn.execute(
        "UPDATE unmatched_payments SET status = 'linked', linked_session_id = ?, resolved_at = ? WHERE id = ?",
        (session_id, now, payment_id)
    )
    conn.commit()
    conn.close()
    log_action(operator_username, 'link_unmatched_payment', session_id, '',
               f'payment_id={payment_id}')
    return {'ok': True}


def resolve_unmatched_payment(payment_id: int, status: str, reason: str, operator_username: str) -> dict:
    conn = _get_admin_db()
    now = datetime.utcnow().isoformat()
    conn.execute(
        "UPDATE unmatched_payments SET status = ?, resolved_reason = ?, resolved_at = ? WHERE id = ?",
        (status, reason, now, payment_id)
    )
    conn.commit()
    conn.close()
    log_action(operator_username, 'resolve_unmatched_payment', '', '',
               f'payment_id={payment_id} status={status} reason={reason[:50]}')
    return {'ok': True}


def get_unmatched_payments() -> list:
    conn = _get_admin_db()
    rows = conn.execute("SELECT * FROM unmatched_payments ORDER BY created_at DESC").fetchall()
    conn.close()
    return [dict(r) for r in rows]


