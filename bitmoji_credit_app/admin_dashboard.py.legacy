@admin_bp.route('/api/toggle-release', methods=['POST'])
@require_operator
def op_toggle_release():
    """Simple toggle: flip release ON or OFF for a consumer."""
    data = request.get_json(force=True)
    sid = data.get('session_id', '')
    action = data.get('action', '')  # 'release' or 'unrelease'

    if not sid or action not in ('release', 'unrelease'):
        return jsonify(error='session_id and action (release/unrelease) required'), 400

    operator = session.get('operator_username', 'unknown')

    if action == 'release':
        result = release_letters(sid, '', '', '', operator)
        if result.get('ok'):
            from database import load_client_by_session, save_client
            profile = load_client_by_session(sid)
            if profile and not profile.get('paid'):
                profile['paid'] = True
                profile['paid_at'] = datetime.utcnow().isoformat()
                profile['status'] = 'released'
                save_client(profile)
        return jsonify(result)
    else:
        # Unrelease — revert to preview
        conn = _get_admin_db()
        now = datetime.utcnow().isoformat()
        conn.execute(
            "UPDATE letter_releases SET revoked = 1, revoked_at = ?, revoked_reason = 'unrelease_toggle' WHERE session_id = ? AND revoked = 0",
            (now, sid)
        )
        conn.execute(
            "UPDATE letter_status SET status = 'preview' WHERE session_id = ? AND status = 'released'",
            (sid,)
        )
        conn.commit()
        conn.close()
        log_action(operator, 'unrelease_toggle', sid, '', 'Toggle flipped OFF')
        return jsonify(ok=True)


@admin_bp.route('/api/generate-confirmation', methods=['POST'])
