# 5 Minutes to Credit Wellness — Environment Variables
# Copy to .env and fill in real values before deployment.

# Required in production (app will not start without these)
FLASK_ENV=production
SECRET_KEY=generate-a-random-64-char-string-here
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin login — generate hash with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$...your.bcrypt.hash.here...

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend-domain.com

# Email (optional — gracefully skipped if not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@yourdomain.com

# OCR (optional — only needed if accepting image uploads)
TESSERACT_CMD=/usr/bin/tesseract

# Database
DB_PATH=creditfix.db

# Session TTL (seconds, default 7200 = 2 hours)
SUBMISSION_TTL_SECONDS=7200
